// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Staff {
  id          Int        @id @default(autoincrement())
  createdAt   DateTime   @default(now())
  email       String     @unique
  firstName   String
  secondName  String
  phoneNumber String     @unique
  password    String
  userType    UserType   @default(LECTURER)
  department  Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  departmentId Int 
  school      School     @relation(fields: [schoolId], references: [id], onDelete: Cascade) // Relationship to School
  schoolId    Int
  userStatus  UserStatus @default(inactive)
  units       Unit[]
}

model Student {
  id          Int        @id @default(autoincrement())
  createdAt   DateTime   @default(now())
  email       String     @unique
  firstName   String
  secondName  String
  password    String
  regNo       String     @unique
  yearOfStudy Int?
  department  Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  departmentId Int
  course      Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId    Int 
  userType    UserType @default(STUDENT)
  userStatus  UserStatus @default(active)
  examMarks   ExamMark[]
  reports     MissingMarksReport[]
  semesterRegistrations SemesterRegistration[]
  suspendedMarks SuspendedExamMark[]
}

model School {
  id          Int         @id @default(autoincrement())
  createdAt   DateTime @default(now())
  name        String
  abbreviation String     @unique
  departments Department[]
  staff       Staff[]
}

model Department {
  id         Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  name       String
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolId   Int
  students   Student[] 
  staffS      Staff[]
  courses    Course[]   
}

model Course {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  name        String
  department  Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  departmentId Int
  students    Student[] 
  units       UnitCourse[]    
}

model Unit {
  id            Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  unitName      String   
  unitCode      String   
  academicYear  String   
  yearOfStudy   Int      
  semester      Semester @default(SEMESTER1)
  lecturer      Staff    @relation(fields: [lecturerId], references: [id], onDelete: Cascade)
  lecturerId    Int
  courses       UnitCourse[]
  marks         ExamMark[]
  missingMarks  MissingMarksReport[]
  registeredUnits RegisteredUnit[]
  suspendedMarks SuspendedExamMark[]
}

model UnitCourse {
  unitId   Int
  courseId Int
  unit     Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([unitId, courseId]) // Composite primary key
}

model SemesterRegistration {
  id            Int      @id @default(autoincrement())
  studentId     Int
  academicYear  String
  semester      Semester
  feesCleared   Boolean  @default(false)
  createdAt     DateTime @default(now())

  student       Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  units         RegisteredUnit[]

  @@unique([studentId, academicYear, semester])
}

model RegisteredUnit {
  registrationId Int
  unitId         Int

  registration   SemesterRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  unit           Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@id([registrationId, unitId])
}

model ExamMark {
  createdAt   DateTime @default(now())
  unitId      Int
  studentId   Int
  examResult  Int
  catResult   Int

  unit        Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)  
  @@id([unitId, studentId])
}

model SuspendedExamMark {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  studentId   Int
  unitId      Int
  examResult  Int
  catResult   Int
  reason      String
  status      ExamSuspensionStatus @default(SUSPENDED)

  unit        Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)  
}

model MissingMarksReport {
  id            Int      @id @default(autoincrement())
  createdAt     DateTime @default(now())
  studentId     Int
  unitId        Int  
  examType      ExamType
  academicYear  String
  semester      Semester
  yearOfStudy   Int
  resolutionNote ResolutionNote?
  reportStatus  ReportStatus @default(PENDING)
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  unit          Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade) 
  notifications Notification[]
   @@unique([studentId, unitId, examType, academicYear, semester])
}

model Notification {
  id          Int      @id @default(autoincrement())
  recipientId Int
  reportId    Int
  role        UserType
  message     String
  sentAt      DateTime @default(now())
  read        Boolean  @default(false)

  report      MissingMarksReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}


enum UserType {
  SUPERADMIN
  ADMIN
  DEAN
  COD
  LECTURER
  STUDENT
}

enum ExamType {
  MAIN
  SPECIAL
  SUPPLIMENTARY
  CAT
  MAIN_AND_CAT
}

enum Semester {
  SEMESTER1
  SEMESTER2
  SEMESTER3
}

enum ReportStatus {
  PENDING
  RESOLVED
  OVERRIDDEN
}

enum UserStatus {
  active
  inactive
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

enum ExamSuspensionStatus {
  SUSPENDED
  RELEASED
}

enum ResolutionNote {
  DID_NOT_SIT_EXAM
  DID_NOT_REGISTER
  DID_NOT_SIT_EXAM_AND_DID_NOT_REGISTER
}